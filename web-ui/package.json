{
  "name": "karaoke-video-creator-ui",
  "version": "1.0.0",
  "description": "Web UI for Karaoke Video Creator",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "pkg . --output ../build/Lyric-Sync-UI-arm64"
  },
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^2.1.1",
    "openai": "^6.10.0"
  },
  "devDependencies": {
    "pkg": "^5.8.1"
  },
  "pkg": {
    "assets": [
      "*.html",
      "app.js"
    ],
    "targets": [
      "node18-macos-arm64"
    ]
  }
}
